# ============================================================
# Mutual – Environment Variables Template
# ------------------------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit the .env file to Git (it is in .gitignore)
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Client Origin (for CORS) ---
CLIENT_URL=http://localhost:5173

# --- MongoDB ---
# Get this from MongoDB Atlas -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/mutual?retryWrites=true&w=majority

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
